# Anthropic API key for the coaching layer (added in Phase 2). Not required for
# the Phase 1 record -> transcribe -> score loop.
ANTHROPIC_API_KEY=

# Optional faster-whisper overrides (defaults shown).
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# Phase 6 — "ideal delivery" voice generation (TTS).
# Server default provider (the Settings tab can override per request).
# Options: local | elevenlabs | openai. Local needs requirements-tts.txt + a GPU.
# TTS_PROVIDER=local
# TTS_LANGUAGE=en

# OpenAI Audio (preset voice; gpt-4o-mini-tts follows the delivery-style text).
# OPENAI_API_KEY=
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy   # alloy|ash|ballad|coral|echo|fable|nova|onyx|sage|shimmer
# CLONE_SR=24000          # sample rate for the clone reference (16k sounds metallic)

# Local XTTS model + decoding tuning (raise/lower to taste if output sounds robotic).
# XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
# XTTS_TEMPERATURE=0.7
# XTTS_REPETITION_PENALTY=2.0
# XTTS_TOP_K=50
# XTTS_TOP_P=0.85
# XTTS_LENGTH_PENALTY=1.0

# ElevenLabs (TTS_PROVIDER=elevenlabs) — clones your voice; requires a PAID plan.
# ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_VOICE_ID=   # optional: reuse a pre-made voice instead of cloning per request

# Voice-generation log (tabular CSV, one row per generation). Default:
# backend/voice_generations.csv
# VOICE_LOG_PATH=/path/to/voice_generations.csv

# Cost estimation rates (USD) for per-generation tracking. Defaults shown.
# Claude (delivery-style) tokens are exact; TTS cost is estimated.
# CLAUDE_USD_PER_MTOK_INPUT=5.0
# CLAUDE_USD_PER_MTOK_OUTPUT=25.0
# OPENAI_TTS_USD_PER_MIN=0.015          # gpt-4o-mini-tts audio
# OPENAI_TTS_USD_PER_MTOK_INPUT=0.60    # gpt-4o-mini-tts input text
# OPENAI_TTS1_USD_PER_MCHAR=15.0        # tts-1 (x2 for tts-1-hd)
