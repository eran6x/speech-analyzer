# Anthropic API key for the coaching layer (added in Phase 2). Not required for
# the Phase 1 record -> transcribe -> score loop.
ANTHROPIC_API_KEY=

# Optional faster-whisper overrides (defaults shown).
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# Phase 6 — "ideal delivery" voice cloning (TTS).
# Provider: local (default) | elevenlabs | none. Local needs requirements-tts.txt + a GPU.
# TTS_PROVIDER=local
# TTS_LANGUAGE=en
# CLONE_SR=24000          # sample rate for the clone reference (16k sounds metallic)

# Local XTTS model + decoding tuning (raise/lower to taste if output sounds robotic).
# XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
# XTTS_TEMPERATURE=0.7
# XTTS_REPETITION_PENALTY=2.0
# XTTS_TOP_K=50
# XTTS_TOP_P=0.85
# XTTS_LENGTH_PENALTY=1.0

# ElevenLabs (TTS_PROVIDER=elevenlabs) — higher quality, cloud.
# ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_VOICE_ID=   # optional: reuse a pre-made voice instead of cloning per request
