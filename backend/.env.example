# Anthropic API key for the coaching layer (added in Phase 2). Not required for
# the Phase 1 record -> transcribe -> score loop.
ANTHROPIC_API_KEY=

# Optional faster-whisper overrides (defaults shown).
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# Phase 6 — "ideal delivery" voice cloning (TTS).
# Provider: local (default) | elevenlabs | none. Local needs requirements-tts.txt + a GPU.
# TTS_PROVIDER=local
# XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
# TTS_LANGUAGE=en
# ELEVENLABS_API_KEY=   # only for the (roadmap) cloud provider
